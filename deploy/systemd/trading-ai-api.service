[Unit]
Description=Trading AI FastAPI service
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/opt/trading-ai
Environment="PYTHONUNBUFFERED=1"
ExecStart=/opt/trading-ai/.venv/bin/python -m uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
