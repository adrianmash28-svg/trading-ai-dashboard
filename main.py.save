python3 main.py√√√√√√√√import math
from dataclasses import dataclass, asdict
from itertools import product
from typing import Dict, List, Tuple

import pandas as pd
import yfinance as yf


# =========================
# SETTINGS
# =========================
SYMBOLS = ["META", "NVDA", "AAPL"]
MARKET_SYMBOL = "SPY"

# Yahoo usually only gives 15m data for about 60 days
DATA_PERIOD = "60d"
DATA_INTERVAL = "15m"

STARTING_EQUITY = 10000.0
RISK_PER_TRADE = 100.0
TRAIN_SPLIT = 0.70

OUTPUT_RESULTS_CSV = "robustness_results.csv"
OUTPUT_TRADES_CSV = "robustness_best_trades.csv"
OUTPUT_SUMMARY_CSV = "robustness_best_summary.csv"


# =========================
# PARAM GRID AROUND STRATEGY C
# =========================
MIN_SCORE_VALUES = [40, 45, 50]
REL_VOL_MIN_VALUES = [1.0, 1.2, 1.4]
ATR_STOP_MULT_VALUES = [0.8, 1.0, 1.2]
TARGET1_R_VALUES = [1.5, 2.0]
TARGET2_R_VALUES = [2.5, 3.0]


# =========================
# DATA CLASSES
# =========================
@dataclass
class Trade:
    strategy_name: str
    symbol: str
    day: str
    entry_time: str
    exit_time: str
    side: str
    entry: float
    stop: float
    target1: float
    target2: float
    shares: int
    pnl: float
    r_multiple: float
    outcome: str


@dataclass
class Summary:
    total_trades: int
    wins: int
    losses: int
    win_rate_pct: float
    total_pnl: float
    avg_pnl: float
    avg_r: float
    best_trade: float
    worst_trade: float
    ending_equity: float
    max_losing_streak: int


# =========================
# HELPERS
# =========================
def download_data(symbol: str) -> pd.DataFrame:
    print(f"Loading {symbol}...")
    df = yf.download(
        symbol,
        period=DATA_PERIOD,
        interval=DATA_INTERVAL,
        auto_adjust=False,
        progress=False,
        threads=False,
    )

    if df is None or df.empty:
        raise ValueError(f"No data returned for {symbol}")

    # Flatten multi-index columns if needed
    if isinstance(df.columns, pd.MultiIndex):
        df.columns = [col[0] for col in df.columns]

    needed = ["Open", "High", "Low", "Close", "Volume"]
    for col in needed:
        if col not in df.columns:
            raise ValueError(f"{symbol} missing column: {col}")

    df = df[needed].copy()
    df = df.dropna().copy()

    if df.empty:
        raise ValueError(f"{symbol} has no usable rows after dropna")

    df.index = pd.to_datetime(df.index)
    return df


def add_indicators(df: pd.DataFrame) -> pd.DataFrame:
    out = df.copy()

    out["sma20"] = out["Close"].rolling(20).mean()
    out["high20"] = out["High"].rolling(20).max()
    out["low20"] = out["Low"].rolling(20).min()
    out["vol_avg20"] = out["Volume"].rolling(20).mean()
    out["rel_vol"] = out["Volume"] / out["vol_avg20"]

    prev_close = out["Close"].shift(1)
    tr1 = out["High"] - out["Low"]
    tr2 = (out["High"] - prev_close).abs()
    tr3 = (out["Low"] - prev_close).abs()
    out["tr"] = pd.concat([tr1, tr2, tr3], axis=1).max(axis=1)
    out["atr14"] = out["tr"].rolling(14).mean()

    out["bar_change_pct"] = ((out["Close"] - prev_close) / prev_close) * 100.0

    return out


def get_common_days(data_map: Dict[str, pd.DataFrame]) -> List[pd.Timestamp]:
    common_sets = []
    for df in data_map.values():
        days = pd.Index(pd.to_datetime(df.index.date).unique())
        common_sets.append(set(days))

    common = sorted(set.intersection(*common_sets))
    return common


def split_days(days: List[pd.Timestamp], train_split: float) -> Tuple[List[pd.Timestamp], List[pd.Timestamp]]:
    split_idx = int(len(days) * train_split)
    train_days = days[:split_idx]
    test_days = days[split_idx:]
    return train_days, test_days


def filter_days(df: pd.DataFrame, selected_days: List[pd.Timestamp]) -> pd.DataFrame:
    if not selected_days:
        return df.iloc[0:0].copy()

    mask = pd.Index(pd.to_datetime(df.index.date)).isin(selected_days)
    return df.loc[mask].copy()


def summarize_trades(trades: List[Trade], starting_equity: float = STARTING_EQUITY) -> Summary:
    if not trades:
        return Summary(
            total_trades=0,
            wins=0,
            losses=0,
            win_rate_pct=0.0,
            total_pnl=0.0,
            avg_pnl=0.0,
            avg_r=0.0,
            best_trade=0.0,
            worst_trade=0.0,
            ending_equity=starting_equity,
            max_losing_streak=0,
        )

    pnls = [t.pnl for t in trades]
    rs = [t.r_multiple for t in trades]
    wins = sum(1 for t in trades if t.pnl > 0)
    losses = sum(1 for t in trades if t.pnl <= 0)

    max_losing_streak = 0
    current_streak = 0
    for t in trades:
        if t.pnl <= 0:
            current_streak += 1
            max_losing_streak = max(max_losing_streak, current_streak)
        else:
            current_streak = 0

    total_pnl = round(sum(pnls), 2)
    total_trades = len(trades)

    return Summary(
        total_trades=total_trades,
        wins=wins,
        losses=losses,
        win_rate_pct=round((wins / total_trades) * 100, 2) if total_trades else 0.0,
        total_pnl=total_pnl,
        avg_pnl=round(total_pnl / total_trades, 2) if total_trades else 0.0,
        avg_r=round(sum(rs) / total_trades, 3) if total_trades else 0.0,
        best_trade=round(max(pnls), 2) if pnls else 0.0,
        worst_trade=round(min(pnls), 2) if pnls else 0.0,
        ending_equity=round(starting_equity + total_pnl, 2),
        max_losing_streak=max_losing_streak,
    )


def print_summary(title: str, summary: Summary) -> None:
    print(f"\n{title}")
    print("-" * len(title))
    print(f"Total trades: {summary.total_trades}")
    print(f"Wins: {summary.wins}")
    print(f"Losses: {summary.losses}")
    print(f"Win rate: {summary.win_rate_pct}%")
    print(f"Total P&L: ${summary.total_pnl}")
    print(f"Average P&L/trade: ${summary.avg_pnl}")
    print(f"Average R: {summary.avg_r}")
    print(f"Best trade: ${summary.best_trade}")
    print(f"Worst trade: ${summary.worst_trade}")
    print(f"Ending equity: ${summary.ending_equity}")
    print(f"Max losing streak: {summary.max_losing_streak}")


# =========================
# STRATEGY C:
# WEAK STOCK + WEAK MARKET
# =========================
def score_short_setup(
    row: pd.Series,
    market_row: pd.Series,
    rel_vol_min: float,
    min_score: int,
) -> int:
    score = 0

    # Weak market
    if market_row["Close"] < market_row["sma20"]:
        score += 20
    if market_row["bar_change_pct"] < 0:
        score += 10

    # Weak stock
    if row["Close"] < row["sma20"]:
        score += 25
    if row["bar_change_pct"] < -0.2:
        score += 15
    if row["rel_vol"] >= rel_vol_min:
        score += 15
    if row["Close"] <= row["low20"] * 1.01:
        score += 15

    return score if score >= min_score else 0


def simulate_short_trade(
    intraday_df: pd.DataFrame,
    entry_idx: int,
    strategy_name: str,
    symbol: str,
    atr_stop_mult: float,
    target1_r: float,
    target2_r: float,
) -> Trade | None:
    row = intraday_df.iloc[entry_idx]

    entry = float(row["Close"])
    atr = float(row["atr14"])

    if math.isnan(atr) or atr <= 0:
        return None

    stop = entry + (atr * atr_stop_mult)
    risk_per_share = stop - entry
    if risk_per_share <= 0:
        return None

    shares = int(RISK_PER_TRADE / risk_per_share)
    if shares <= 0:
        return None

    target1 = entry - (risk_per_share * target1_r)
    target2 = entry - (risk_per_share * target2_r)

    after = intraday_df.iloc[entry_idx + 1 :].copy()
    if after.empty:
        return None

    half_shares = shares // 2
    remaining_shares = shares - half_shares

    realized_pnl = 0.0
    t1_hit = False
    exit_time = str(after.index[-1])
    outcome = "EOD"
    stop_after_t1 = stop

    for ts, bar in after.iterrows():
        high_ = float(bar["High"])
        low_ = float(bar["Low"])
        close_ = float(bar["Close"])

        # Stop before T1
        if not t1_hit and high_ >= stop:
            pnl = (entry - stop) * shares
            realized_pnl += pnl
            exit_time = str(ts)
            outcome = "STOP"
            r_mult = realized_pnl / RISK_PER_TRADE
            return Trade(
                strategy_name=strategy_name,
                symbol=symbol,
                day=str(pd.Timestamp(ts).date()),
                entry_time=str(intraday_df.index[entry_idx]),
                exit_time=exit_time,
                side="SHORT",
                entry=round(entry, 4),
                stop=round(stop, 4),
                target1=round(target1, 4),
                target2=round(target2, 4),
                shares=shares,
                pnl=round(realized_pnl, 2),
                r_multiple=round(r_mult, 3),
                outcome=outcome,
            )

        # Target1 hit
        if not t1_hit and low_ <= target1:
            realized_pnl += (entry - target1) * half_shares
            t1_hit = True
            stop_after_t1 = entry  # move stop to breakeven

        # After T1, either T2 or BE stop
        if t1_hit:
            if low_ <= target2:
                realized_pnl += (entry - target2) * remaining_shares
                exit_time = str(ts)
                outcome = "T2"
                r_mult = realized_pnl / RISK_PER_TRADE
                return Trade(
                    strategy_name=strategy_name,
                    symbol=symbol,
                    day=str(pd.Timestamp(ts).date()),
                    entry_time=str(intraday_df.index[entry_idx]),
                    exit_time=exit_time,
                    side="SHORT",
                    entry=round(entry, 4),
                    stop=round(stop, 4),
                    target1=round(target1, 4),
                    target2=round(target2, 4),
                    shares=shares,
                    pnl=round(realized_pnl, 2),
                    r_multiple=round(r_mult, 3),
                    outcome=outcome,
                )

            if high_ >= stop_after_t1:
                realized_pnl += (entry - stop_after_t1) * remaining_shares
                exit_time = str(ts)
                outcome = "T1_BE"
                r_mult = realized_pnl / RISK_PER_TRADE
                return Trade(
                    strategy_name=strategy_name,
                    symbol=symbol,
                    day=str(pd.Timestamp(ts).date()),
                    entry_time=str(intraday_df.index[entry_idx]),
                    exit_time=exit_time,
                    side="SHORT",
                    entry=round(entry, 4),
                    stop=round(stop, 4),
                    target1=round(target1, 4),
                    target2=round(target2, 4),
                    shares=shares,
                    pnl=round(realized_pnl, 2),
                    r_multiple=round(r_mult, 3),
                    outcome=outcome,
                )

    # End of day exit
    last_close = float(after.iloc[-1]["Close"])
    if t1_hit:
        realized_pnl += (entry - last_close) * remaining_shares
    else:
        realized_pnl += (entry - last_close) * shares

    r_mult = realized_pnl / RISK_PER_TRADE
    return Trade(
        strategy_name=strategy_name,
        symbol=symbol,
        day=str(pd.Timestamp(after.index[-1]).date()),
        entry_time=str(intraday_df.index[entry_idx]),
        exit_time=str(after.index[-1]),
        side="SHORT",
        entry=round(entry, 4),
        stop=round(stop, 4),
        target1=round(target1, 4),
        target2=round(target2, 4),
        shares=shares,
        pnl=round(realized_pnl, 2),
        r_multiple=round(r_mult, 3),
        outcome="EOD",
    )


def backtest_strategy_c(
    stock_data: Dict[str, pd.DataFrame],
    market_data: pd.DataFrame,
    selected_days: List[pd.Timestamp],
    strategy_name: str,
    rel_vol_min: float,
    min_score: int,
    atr_stop_mult: float,
    target1_r: float,
    target2_r: float,
) -> List[Trade]:
    trades: List[Trade] = []

    market_filtered = filter_days(market_data, selected_days)
    if market_filtered.empty:
        return trades

    for symbol, full_df in stock_data.items():
        df = filter_days(full_df, selected_days)
        if df.empty:
            continue

        # Group by day
        grouped = df.groupby(pd.to_datetime(df.index.date))

        for day, day_df in grouped:
            day_df = day_df.copy()
            if len(day_df) < 25:
                continue

            market_day = market_filtered[market_filtered.index.date == day]
            if market_day.empty or len(market_day) < 25:
                continue

            # Use aligned times
            common_index = day_df.index.intersection(market_day.index)
            if len(common_index) < 25:
                continue

            day_df = day_df.loc[common_index].copy()
            market_day = market_day.loc[common_index].copy()

            # One trade max per symbol per day
            trade_taken = False

            # Skip first 15 minutes to reduce open noise
            for i in range(1, len(day_df)):
                ts = day_df.index[i]

                row = day_df.loc[ts]
                market_row = market_day.loc[ts]

                needed = [
                    row["sma20"], row["low20"], row["rel_vol"], row["atr14"],
                    market_row["sma20"]
                ]
                if any(pd.isna(x) for x in needed):
                    continue

                score = score_short_setup(
                    row=row,
                    market_row=market_row,
                    rel_vol_min=rel_vol_min,
                    min_score=min_score,
                )

                if score <= 0:
                    continue

                trade = simulate_short_trade(
                    intraday_df=day_df,
                    entry_idx=i,
                    strategy_name=strategy_name,
                    symbol=symbol,
                    atr_stop_mult=atr_stop_mult,
                    target1_r=target1_r,
                    target2_r=target2_r,
                )

                if trade is not None:
                    trades.append(trade)
                    trade_taken = True
                    break

            if trade_taken:
                continue

    trades.sort(key=lambda t: t.entry_time)
    return trades


# =========================
# MAIN
# =========================
def main() -> None:
    print("Downloading data...")

    raw_data: Dict[str, pd.DataFrame] = {}
    for symbol in SYMBOLS + [MARKET_SYMBOL]:
        raw_data[symbol] = add_indicators(download_data(symbol))

    stock_data = {s: raw_data[s] for s in SYMBOLS}
    market_data = raw_data[MARKET_SYMBOL]

    common_days = get_common_days(raw_data)
    if len(common_days) < 20:
        raise ValueError("Not enough common days across symbols.")

    train_days, test_days = split_days(common_days, TRAIN_SPLIT)

    print(f"\nTotal common days: {len(common_days)}")
    print(f"In-sample days: {len(train_days)}")
    print(f"Out-of-sample days: {len(test_days)}")

    grid = list(product(
        MIN_SCORE_VALUES,
        REL_VOL_MIN_VALUES,
        ATR_STOP_MULT_VALUES,
        TARGET1_R_VALUES,
        TARGET2_R_VALUES,
    ))

    print(f"\nRunning robustness test on {len(grid)} Strategy C variations...")

    results: List[Dict] = []
    best_test_score = -10**9
    best_test_trades: List[Trade] = []
    best_test_summary: Summary | None = None
    best_name = ""

    for idx, (min_score, rel_vol_min, atr_stop_mult, target1_r, target2_r) in enumerate(grid, start=1):
        name = (
            f"C_ms{min_score}_rv{rel_vol_min}_"
            f"atr{atr_stop_mult}_t1{target1_r}_t2{target2_r}"
        )

        print(
            f"[{idx}/{len(grid)}] Testing "
            f"MIN_SCORE={min_score}, REL_VOL_MIN={rel_vol_min}, "
            f"ATR_STOP={atr_stop_mult}, T1={target1_r}, T2={target2_r}"
        )

        train_trades = backtest_strategy_c(
            stock_data=stock_data,
            market_data=market_data,
            selected_days=train_days,
            strategy_name=name,
            rel_vol_min=rel_vol_min,
            min_score=min_score,
            atr_stop_mult=atr_stop_mult,
            target1_r=target1_r,
            target2_r=target2_r,
        )
        test_trades = backtest_strategy_c(
            stock_data=stock_data,
            market_data=market_data,
            selected_days=test_days,
            strategy_name=name,
            rel_vol_min=rel_vol_min,
            min_score=min_score,
            atr_stop_mult=atr_stop_mult,
            target1_r=target1_r,
            target2_r=target2_r,
        )

        train_summary = summarize_trades(train_trades)
        test_summary = summarize_trades(test_trades)

        # Score unseen data higher than in-sample
        score = (
            test_summary.total_pnl
            + (test_summary.avg_r * 1000)
            + (test_summary.win_rate_pct * 10)
            - (test_summary.max_losing_streak * 25)
        )

        # Penalize tiny sample size
        if test_summary.total_trades < 8:
            score -= 1000

        row = {
            "strategy_name": name,
            "min_score": min_score,
            "rel_vol_min": rel_vol_min,
            "atr_stop_mult": atr_stop_mult,
            "target1_r": target1_r,
            "target2_r": target2_r,

            "train_trades": train_summary.total_trades,
            "train_win_rate_pct": train_summary.win_rate_pct,
            "train_total_pnl": train_summary.total_pnl,
            "train_avg_r": train_summary.avg_r,

            "test_trades": test_summary.total_trades,
            "test_win_rate_pct": test_summary.win_rate_pct,
            "test_total_pnl": test_summary.total_pnl,
            "test_avg_r": test_summary.avg_r,
            "test_max_losing_streak": test_summary.max_losing_streak,

            "score": round(score, 2),
        }
        results.append(row)

        if score > best_test_score:
            best_test_score = score
            best_test_trades = test_trades
            best_test_summary = test_summary
            best_name = name

    results_df = pd.DataFrame(results)
    results_df = results_df.sort_values(
        by=["score", "test_total_pnl", "test_avg_r", "test_win_rate_pct", "test_trades"],
        ascending=[False, False, False, False, False],
    ).reset_index(drop=True)

    results_df.to_csv(OUTPUT_RESULTS_CSV, index=False)

    print("\nTop 10 robustness results:\n")
    show_cols = [
        "strategy_name",
        "min_score",
        "rel_vol_min",
        "atr_stop_mult",
        "target1_r",
        "target2_r",
        "train_trades",
        "train_total_pnl",
        "test_trades",
        "test_win_rate_pct",
        "test_total_pnl",
        "test_avg_r",
        "test_max_losing_streak",
        "score",
    ]

    for i, row in results_df.head(10).iterrows():
        print(f"Rank #{i + 1}")
        for col in show_cols:
            print(f"{col}: {row[col]}")
        print("-" * 50)

    if best_test_summary is None:
        print("\nNo valid best strategy found.")
        return

    print(f"\nBEST ROBUST STRATEGY: {best_name}")
    print_summary("BEST OUT-OF-SAMPLE SUMMARY", best_test_summary)

    if best_test_trades:
        pd.DataFrame([asdict(t) for t in best_test_trades]).to_csv(OUTPUT_TRADES_CSV, index=False)

    pd.DataFrame([asdict(best_test_summary)]).to_csv(OUTPUT_SUMMARY_CSV, index=False)

    print(f"\nSaved robustness table to {OUTPUT_RESULTS_CSV}")
    print(f"Saved best out-of-sample trades to {OUTPUT_TRADES_CSV}")
    print(f"Saved best out-of-sample summary to {OUTPUT_SUMMARY_CSV}")


if __name__ == "__main__":
    main()
